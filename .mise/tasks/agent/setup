#!/usr/bin/env bash
#MISE description="Installer le venv agent-harness (à faire une fois par machine)"
set -euo pipefail

HARNESS_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}/agent-harness"

echo "=== Installation agent-harness ==="
echo "Répertoire : $HARNESS_DIR"
echo ""

if [ ! -f "$HARNESS_DIR/pyproject.toml" ]; then
    echo "[ERREUR] agent-harness introuvable dans $HARNESS_DIR"
    echo "Vérifiez que le repo est bien cloné."
    exit 1
fi

FORCE="${1:-}"

if [ -f "$HARNESS_DIR/.venv/bin/harness" ] && [ "$FORCE" != "--force" ]; then
    echo "[OK] Le venv existe déjà"
    "$HARNESS_DIR/.venv/bin/harness" --help 2>&1 | head -3 || true
    echo ""
    echo "Pour réinstaller : mise run agent:setup -- --force"
    exit 0
fi

echo "[...] Création du venv..."
python3 -m venv "$HARNESS_DIR/.venv"

echo "[...] Installation des dépendances..."
PIP="$HARNESS_DIR/.venv/bin/pip"

# Upgrade pip
"$PIP" install --upgrade pip -q 2>/dev/null || true

# TOUJOURS configurer PyPI public en fallback.
# Pourquoi : `pip install -e .` utilise l'isolation de build qui crée un
# sous-processus temporaire. Ce sous-processus n'hérite PAS des packages
# installés dans le venv, il retélécharge les build dependencies (hatchling)
# depuis zéro en utilisant la config pip du venv. Si seul Artifactory est
# configuré et ne mirror pas hatchling → échec silencieux.
# Configurer extra-index-url de manière permanente est la seule solution fiable.
PYPI_FALLBACK="${PIP_EXTRA_INDEX_URL:-https://pypi.org/simple/}"

# Détecter si un registry corporate est configuré (index-url != pypi.org)
CURRENT_INDEX=$("$PIP" config get global.index-url 2>/dev/null || echo "")
if [ -n "$CURRENT_INDEX" ] && ! echo "$CURRENT_INDEX" | grep -q "pypi.org"; then
    echo "    [i] Registry corporate détecté : $CURRENT_INDEX"
    echo "    [i] Ajout de PyPI public en fallback : $PYPI_FALLBACK"
    "$PIP" config set global.extra-index-url "$PYPI_FALLBACK" 2>/dev/null || true
elif ! "$PIP" install --dry-run hatchling -q 2>/dev/null; then
    # Pas de registry corporate explicite mais hatchling introuvable quand même
    echo "    [i] hatchling introuvable, ajout de PyPI public en fallback"
    "$PIP" config set global.extra-index-url "$PYPI_FALLBACK" 2>/dev/null || true
fi

"$PIP" install -e "$HARNESS_DIR[dev,rag]" -q || {
    echo ""
    echo "[ERREUR] Échec de l'installation des dépendances"
    echo ""
    echo "  Le registry pip actuel ne contient pas tous les packages requis."
    echo "  Essayez :"
    echo "    $PIP config set global.extra-index-url https://pypi.org/simple/"
    echo "    mise run agent:setup -- --force"
    echo ""
    echo "  Si pypi.org est aussi bloqué par le proxy, demandez à votre admin"
    echo "  réseau d'autoriser pypi.org ou d'ajouter ces packages à Artifactory :"
    echo "    hatchling, chromadb, ollama, pydantic, typer, jsonschema"
    exit 1
}

echo ""
echo "[OK] agent-harness installé"
"$HARNESS_DIR/.venv/bin/harness" --help | head -3 || true

# Vérifier les modèles requis
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"
echo ""
echo "=== Vérification des modèles Ollama ==="
source "$REPO_DIR/scripts/ensure-model.sh"
for MODEL in gemma4:26b-a4b-it-q8_0 gemma:7b-instruct; do
    if ollama list 2>/dev/null | grep -q "$MODEL"; then
        echo "[OK] $MODEL installé"
    else
        echo ""
        _ensure_model "$MODEL" || echo "[!] $MODEL non installé — vous pourrez l'installer plus tard"
    fi
done

echo ""
echo "Prochaines étapes :"
echo ""
echo "  1. Lancer un agent local (Gemma 4) :"
echo "     mise run agent:coding -- \"votre tâche\""
echo "     mise run agent:doc -- \"votre tâche\""
echo ""
echo "  2. Lancer un agent en ligne :"
echo "     mise run agent:claude -- \"votre tâche\"   (ANTHROPIC_API_KEY requis)"
echo "     mise run agent:copilot -- \"votre tâche\"  (GITHUB_TOKEN requis)"
echo ""
echo "  3. Lancer les évaluations :"
echo "     mise run agent:eval -- gemma4"
echo ""
echo "  4. Voir toutes les commandes :"
echo "     mise task ls"
