#!/usr/bin/env bash
#MISE description="Installer le venv agent-harness (à faire une fois par machine)"
set -euo pipefail

HARNESS_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}/agent-harness"

echo "=== Installation agent-harness ==="
echo "Répertoire : $HARNESS_DIR"
echo ""

if [ ! -f "$HARNESS_DIR/pyproject.toml" ]; then
    echo "[ERREUR] agent-harness introuvable dans $HARNESS_DIR"
    echo "Vérifiez que le repo est bien cloné."
    exit 1
fi

FORCE="${1:-}"

if [ -f "$HARNESS_DIR/.venv/bin/harness" ] && [ "$FORCE" != "--force" ]; then
    echo "[OK] Le venv existe déjà"
    "$HARNESS_DIR/.venv/bin/harness" --help 2>&1 | head -3 || true
    echo ""
    echo "Pour réinstaller : mise run agent:setup -- --force"
    exit 0
fi

echo "[...] Création du venv..."
python3 -m venv "$HARNESS_DIR/.venv"

echo "[...] Installation des dépendances..."
"$HARNESS_DIR/.venv/bin/pip" install --upgrade pip -q
"$HARNESS_DIR/.venv/bin/pip" install -e "$HARNESS_DIR[dev,rag]" -q

echo ""
echo "[OK] agent-harness installé"
"$HARNESS_DIR/.venv/bin/harness" --help | head -3 || true

# Vérifier les modèles requis
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"
echo ""
echo "=== Vérification des modèles Ollama ==="
source "$REPO_DIR/scripts/ensure-model.sh"
for MODEL in gemma4:26b-a4b-it-q8_0 gemma:7b-instruct; do
    if ollama list 2>/dev/null | grep -q "$MODEL"; then
        echo "[OK] $MODEL installé"
    else
        echo ""
        _ensure_model "$MODEL" || echo "[!] $MODEL non installé — vous pourrez l'installer plus tard"
    fi
done

echo ""
echo "Prochaines étapes :"
echo ""
echo "  1. Lancer un agent local (Gemma 4) :"
echo "     mise run agent:coding -- \"votre tâche\""
echo "     mise run agent:doc -- \"votre tâche\""
echo ""
echo "  2. Lancer un agent en ligne :"
echo "     mise run agent:claude -- \"votre tâche\"   (ANTHROPIC_API_KEY requis)"
echo "     mise run agent:copilot -- \"votre tâche\"  (GITHUB_TOKEN requis)"
echo ""
echo "  3. Lancer les évaluations :"
echo "     mise run agent:eval -- gemma4"
echo ""
echo "  4. Voir toutes les commandes :"
echo "     mise task ls"
