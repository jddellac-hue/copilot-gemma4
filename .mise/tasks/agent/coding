#!/usr/bin/env bash
#MISE description="Lancer l'agent coding (harness + gemma4:26b-a4b-it-q8_0)"
set -euo pipefail

TASK="${1:-}"
WORKSPACE="${2:-.}"
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"

if [ -z "$TASK" ]; then
    echo "Usage: mise run agent:coding -- \"<tâche>\" [workspace]"
    echo ""
    echo "  mise run agent:coding -- \"Écris une fonction de tri\""
    echo "  mise run agent:coding -- \"Trouve les bugs\" /chemin/projet"
    echo ""
    echo "Autres : agent:doc, agent:claude, agent:copilot"
    exit 1
fi

source "$REPO_DIR/scripts/harness-run.sh"
harness_run coding "$TASK" "$WORKSPACE"
