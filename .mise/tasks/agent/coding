#!/usr/bin/env bash
#MISE description="Lancer l'agent coding (harness + gemma4:26b-a4b-it-q8_0)"
set -euo pipefail

TASK="${1:-}"
WORKSPACE="${2:-.}"
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"
HARNESS_DIR="$REPO_DIR/agent-harness"
PROFILE="$HARNESS_DIR/config/profiles/gemma4-coding.yaml"
MODEL="${GEMMA4_CODING_MODEL:-gemma4:26b-a4b-it-q8_0}"

if [ -z "$TASK" ]; then
    echo "Usage: mise run agent:coding -- \"<tâche>\" [workspace]"
    echo ""
    echo "Exemples :"
    echo "  mise run agent:coding -- \"Écris une fonction de tri\""
    echo "  mise run agent:coding -- \"Trouve et corrige les bugs\" /chemin/projet"
    echo ""
    echo "Profil : $PROFILE"
    echo "Modèle : $MODEL"
    echo ""
    echo "Autres agents disponibles :"
    echo "  mise run agent:doc     -- \"...\"   Documentation (Gemma 4 local)"
    echo "  mise run agent:claude  -- \"...\"   Claude Sonnet (en ligne)"
    echo "  mise run agent:copilot -- \"...\"   GitHub Copilot (en ligne)"
    exit 1
fi

# Vérifier le harness
if [ ! -f "$HARNESS_DIR/.venv/bin/harness" ]; then
    echo "[ERREUR] agent-harness non installé"
    echo "Lancez : mise run agent:setup"
    exit 1
fi

# Vérifier et précharger le modèle
source "$REPO_DIR/scripts/ensure-model.sh"
_ensure_model "$MODEL" || exit 1

# Lancer le harness
exec "$HARNESS_DIR/.venv/bin/harness" run \
    --profile "$PROFILE" \
    --workspace "$WORKSPACE" \
    "$TASK"
