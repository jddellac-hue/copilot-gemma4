#!/usr/bin/env bash
#MISE description="Lancer l'agent coding (harness + gemma4:26b-a4b-it-q8_0)"
set -euo pipefail

TASK="${1:-}"
WORKSPACE="${2:-.}"
HARNESS_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}/agent-harness"
PROFILE="$HARNESS_DIR/config/profiles/gemma4-coding.yaml"

if [ -z "$TASK" ]; then
    echo "Usage: mise run agent:coding -- \"<tâche>\" [workspace]"
    echo ""
    echo "Exemples :"
    echo "  mise run agent:coding -- \"Écris une fonction de tri\""
    echo "  mise run agent:coding -- \"Trouve et corrige les bugs\" /chemin/projet"
    echo ""
    echo "Profil : $PROFILE"
    echo "Modèle : gemma4:26b-a4b-it-q8_0 (dense, lent mais précis)"
    exit 1
fi

# Décharger les autres modèles
curl -sf http://localhost:11434/api/ps 2>/dev/null | python3 -c "
import sys,json
d=json.load(sys.stdin)
for m in d.get('models',[]):
    if m['name'] != 'gemma4:26b-a4b-it-q8_0':
        import urllib.request
        req = urllib.request.Request('http://localhost:11434/api/generate',
            data=json.dumps({'model':m['name'],'keep_alive':0}).encode(),
            headers={'Content-Type':'application/json'})
        urllib.request.urlopen(req, timeout=5)
" 2>/dev/null || true

# Lancer le harness
source "$HARNESS_DIR/.venv/bin/activate"
exec harness run \
    --profile "$PROFILE" \
    --workspace "$WORKSPACE" \
    "$TASK"
