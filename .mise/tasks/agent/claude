#!/usr/bin/env bash
#MISE description="Lancer l'agent coding avec Claude (API Anthropic)"
set -euo pipefail

TASK="${1:-}"
WORKSPACE="${2:-.}"
HARNESS_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}/agent-harness"
PROFILE="$HARNESS_DIR/config/profiles/claude-online.yaml"
MODEL="${CLAUDE_MODEL:-claude-sonnet-4-20250514}"

if [ -z "$TASK" ]; then
    echo "Usage: mise run agent:claude -- \"<tâche>\" [workspace]"
    echo ""
    echo "Exemples :"
    echo "  mise run agent:claude -- \"Écris une fonction de tri\""
    echo "  mise run agent:claude -- \"Trouve et corrige les bugs\" /chemin/projet"
    echo ""
    echo "Profil : $PROFILE"
    echo "Modèle : $MODEL"
    echo "Prérequis : ANTHROPIC_API_KEY dans l'environnement"
    echo ""
    echo "Autres agents disponibles :"
    echo "  mise run agent:coding  -- \"...\"   Gemma 4 (local, gratuit)"
    echo "  mise run agent:copilot -- \"...\"   GitHub Copilot (en ligne)"
    echo ""
    echo "Évaluations : mise run agent:eval -- claude"
    exit 1
fi

# Vérifier le harness
if [ ! -f "$HARNESS_DIR/.venv/bin/harness" ]; then
    echo "[ERREUR] agent-harness non installé"
    echo "Lancez : mise run agent:setup"
    exit 1
fi

# Vérifier la clé API
if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
    echo "[ERREUR] ANTHROPIC_API_KEY non définie"
    echo "export ANTHROPIC_API_KEY=sk-ant-..."
    exit 1
fi

# Lancer le harness
exec "$HARNESS_DIR/.venv/bin/harness" run \
    --profile "$PROFILE" \
    --workspace "$WORKSPACE" \
    "$TASK"
