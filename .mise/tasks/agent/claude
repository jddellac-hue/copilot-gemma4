#!/usr/bin/env bash
#MISE description="Lancer l'agent coding avec Claude (API Anthropic)"
set -euo pipefail

TASK="${1:-}"
WORKSPACE="${2:-.}"
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"

if [ -z "$TASK" ]; then
    echo "Usage: mise run agent:claude -- \"<tâche>\" [workspace]"
    echo ""
    echo "  Prérequis : ANTHROPIC_API_KEY"
    echo ""
    echo "Autres : agent:coding, agent:copilot"
    exit 1
fi

source "$REPO_DIR/scripts/harness-run.sh"
harness_run claude "$TASK" "$WORKSPACE"
