#!/usr/bin/env bash
#MISE description="Démarrer le serveur OpenAI-compatible (pour IntelliJ, Continue.dev, etc.)"
set -euo pipefail

PROFILE="${1:-coding}"
WORKSPACE="${2:-.}"
HOST="${3:-127.0.0.1}"
PORT="${4:-11500}"
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"

source "$REPO_DIR/scripts/harness-run.sh"

PROFILE_PATH=$(_resolve_profile "$PROFILE")
if [ -z "$PROFILE_PATH" ]; then
    echo "Usage: mise run agent:serve -- [coding|doc|dev|claude|copilot] [workspace] [host] [port]"
    echo ""
    echo "Serveur OpenAI-compatible sur http://HOST:PORT/v1"
    echo ""
    echo "Pour IntelliJ : Settings > AI Assistant > Custom LLM"
    echo "  URL : http://127.0.0.1:11500/v1   Clé : any-key-works"
    exit 1
fi

_check_harness
_check_env "$PROFILE"
_ensure_local_model "$PROFILE_PATH"

exec "$HARNESS_DIR/.venv/bin/harness" openai-serve \
    --profile "$PROFILE_PATH" \
    --workspace "$WORKSPACE" \
    --host "$HOST" \
    --port "$PORT"
