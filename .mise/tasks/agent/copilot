#!/usr/bin/env bash
#MISE description="Lancer l'agent coding avec GitHub Copilot (Models API)"
set -euo pipefail

TASK="${1:-}"
WORKSPACE="${2:-.}"
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"

if [ -z "$TASK" ]; then
    echo "Usage: mise run agent:copilot -- \"<tâche>\" [workspace]"
    echo ""
    echo "  Prérequis : GITHUB_TOKEN (scope copilot/models)"
    echo ""
    echo "Autres : agent:coding, agent:claude"
    exit 1
fi

source "$REPO_DIR/scripts/harness-run.sh"
harness_run copilot "$TASK" "$WORKSPACE"
