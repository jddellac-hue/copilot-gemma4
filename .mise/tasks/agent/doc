#!/usr/bin/env bash
#MISE description="Lancer l'agent documentation (harness + gemma4:26b-a4b-it-q8_0)"
set -euo pipefail

TASK="${1:-}"
WORKSPACE="${2:-.}"
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"

if [ -z "$TASK" ]; then
    echo "Usage: mise run agent:doc -- \"<tâche>\" [workspace]"
    echo ""
    echo "  mise run agent:doc -- \"Génère la doc API pour src/api/\""
    echo "  mise run agent:doc -- \"Écris un README\" /chemin/projet"
    echo ""
    echo "Autres : agent:coding, agent:claude, agent:copilot"
    exit 1
fi

source "$REPO_DIR/scripts/harness-run.sh"
harness_run doc "$TASK" "$WORKSPACE"
