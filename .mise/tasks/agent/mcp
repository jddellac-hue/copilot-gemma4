#!/usr/bin/env bash
#MISE description="Démarrer le serveur MCP (pour VS Code / Copilot / Claude Desktop)"
set -euo pipefail

ROLE="${1:-coding}"
WORKSPACE="${2:-.}"
REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"

source "$REPO_DIR/scripts/harness-run.sh"

PROFILE_PATH=$(_resolve_profile "$ROLE")
if [ -z "$PROFILE_PATH" ]; then
    echo "Usage: mise run agent:mcp -- [coding|doc] [workspace]"
    echo ""
    echo "Démarre un serveur MCP exposant les outils du harness."
    exit 1
fi

_check_harness
_ensure_local_model "$PROFILE_PATH"

exec "$HARNESS_DIR/.venv/bin/harness" mcp-serve \
    --profile "$PROFILE_PATH" \
    --workspace "$WORKSPACE"
