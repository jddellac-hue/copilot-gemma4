#!/usr/bin/env bash
#MISE description="Vérifier qu'un modèle fonctionne (ex: gemma4:26b)"
set -euo pipefail

MODEL="${1:-}"

if [ -z "$MODEL" ]; then
    echo "Usage: mise run test:verify -- <modèle>"
    echo ""
    echo "Modèles installés :"
    ollama list 2>/dev/null | tail -n +2 || echo "  (aucun)"
    exit 1
fi

# Normaliser
if [[ "$MODEL" != gemma4:* ]]; then
    MODEL="gemma4:${MODEL}"
fi

if ! ollama list 2>/dev/null | grep -q "$MODEL"; then
    echo "[ERREUR] $MODEL n'est pas installé"
    echo "Lancez : mise run model:install -- $MODEL"
    exit 1
fi

PROMPT="${GEMMA4_TEST_PROMPT:-Explique en 2 phrases ce qu'est un transformer en deep learning.}"

echo "=== Vérification de $MODEL ==="
echo "Prompt : $PROMPT"
echo ""

# Décharger les autres modèles pour libérer la RAM
echo "[...] Libération de la mémoire..."
LOADED=$(curl -sf http://localhost:11434/api/ps 2>/dev/null | python3 -c "
import sys,json
d=json.load(sys.stdin)
for m in d.get('models',[]):
    print(m['name'])
" 2>/dev/null || true)

for loaded_model in $LOADED; do
    if [ "$loaded_model" != "$MODEL" ]; then
        curl -sf http://localhost:11434/api/generate -d "{\"model\":\"$loaded_model\",\"keep_alive\":0}" > /dev/null 2>&1 || true
    fi
done

echo "[...] Envoi du prompt de test..."
start_time=$(date +%s%N)

response=$(ollama run "$MODEL" "$PROMPT" 2>&1) || {
    echo "[ERREUR] Le modèle n'a pas répondu"
    echo "$response"
    exit 1
}

end_time=$(date +%s%N)
duration_ms=$(( (end_time - start_time) / 1000000 ))
duration_s=$(echo "scale=1; $duration_ms / 1000" | bc)

if [ -n "$response" ] && [ ${#response} -gt 10 ]; then
    echo "[OK] Réponse reçue en ${duration_s}s (${#response} caractères)"
    echo ""
    echo "--- Réponse ---"
    echo "$response"
    echo "---------------"
else
    echo "[ERREUR] Réponse vide ou trop courte"
    exit 1
fi

# Décharger après le test
curl -sf http://localhost:11434/api/generate -d "{\"model\":\"$MODEL\",\"keep_alive\":0}" > /dev/null 2>&1 || true
echo ""
echo "[OK] Modèle déchargé de la mémoire"
