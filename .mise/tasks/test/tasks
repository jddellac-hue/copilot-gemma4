#!/usr/bin/env bash
#MISE description="Tests unitaires des tasks mise (existence, usage, prérequis)"
set -uo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Couleurs et helpers
# ─────────────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

PASS=0
FAIL=0
TOTAL_START=$(date +%s)

section()  { echo -e "\n${BLUE}${BOLD}━━━ $1 ━━━${NC}"; }
ok()       { echo -e "  ${GREEN}✓${NC} $1"; PASS=$((PASS + 1)); }
fail()     { echo -e "  ${RED}✗${NC} $1"; FAIL=$((FAIL + 1)); }
detail()   { echo -e "    ${DIM}$1${NC}"; }

REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"
TASKS_DIR="$REPO_DIR/.mise/tasks"
HARNESS_DIR="$REPO_DIR/agent-harness"

echo -e "${BOLD}"
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║         Tests unitaires des tasks mise (25 tasks)           ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo -e "${NC}"

# ─────────────────────────────────────────────────────────────────────────────
# 1. Toutes les tasks existent et sont exécutables
# ─────────────────────────────────────────────────────────────────────────────
section "1/6 — Existence et permissions"

EXPECTED_TASKS=(
    "agent/setup"
    "agent/coding"
    "agent/doc"
    "agent/claude"
    "agent/copilot"
    "agent/eval"
    "agent/mcp"
    "agent/serve"
    "chat"
    "model/install"
    "model/uninstall"
    "model/list"
    "model/start"
    "model/stop"
    "model/evaluate"
    "test/verify"
    "test/bench"
    "test/tasks"
    "test/system"
    "tui/bench"
    "tui/install"
    "prereqs/install"
    "prereqs/uninstall"
    "clean"
    "verify"
)

for task in "${EXPECTED_TASKS[@]}"; do
    TASK_FILE="$TASKS_DIR/$task"
    if [ -f "$TASK_FILE" ]; then
        if [ -x "$TASK_FILE" ]; then
            ok "$task (exécutable)"
        else
            fail "$task existe mais n'est pas exécutable (chmod +x)"
        fi
    else
        fail "$task n'existe pas"
    fi
done

# ─────────────────────────────────────────────────────────────────────────────
# 2. Toutes les tasks ont une description MISE
# ─────────────────────────────────────────────────────────────────────────────
section "2/6 — Descriptions MISE"

for task in "${EXPECTED_TASKS[@]}"; do
    TASK_FILE="$TASKS_DIR/$task"
    [ -f "$TASK_FILE" ] || continue
    DESC=$(grep -oP '#MISE description="\K[^"]+' "$TASK_FILE" 2>/dev/null || true)
    if [ -n "$DESC" ]; then
        ok "$task : $DESC"
    else
        fail "$task : pas de description #MISE"
    fi
done

# ─────────────────────────────────────────────────────────────────────────────
# 3. Toutes les tasks ont un shebang valide
# ─────────────────────────────────────────────────────────────────────────────
section "3/6 — Shebangs"

for task in "${EXPECTED_TASKS[@]}"; do
    TASK_FILE="$TASKS_DIR/$task"
    [ -f "$TASK_FILE" ] || continue
    SHEBANG=$(head -1 "$TASK_FILE")
    if [[ "$SHEBANG" =~ ^#!.*(bash|python3|sh) ]]; then
        ok "$task : $SHEBANG"
    else
        fail "$task : shebang invalide ou manquant ($SHEBANG)"
    fi
done

# ─────────────────────────────────────────────────────────────────────────────
# 4. Les tasks agent affichent un usage quand appelées sans arguments
# ─────────────────────────────────────────────────────────────────────────────
section "4/6 — Messages d'usage (appel sans arguments)"

TASKS_WITH_USAGE=(
    "agent/coding"
    "agent/doc"
    "agent/claude"
    "agent/copilot"
    "agent/eval"
)

for task in "${TASKS_WITH_USAGE[@]}"; do
    TASK_FILE="$TASKS_DIR/$task"
    [ -f "$TASK_FILE" ] || continue
    # On exécute la task sans argument, elle doit afficher "Usage:" et sortir code 1
    OUTPUT=$("$TASK_FILE" 2>&1 || true)
    if echo "$OUTPUT" | grep -qi "usage"; then
        ok "$task affiche un message d'usage"
        # Vérifier qu'il mentionne aussi les alternatives
        if echo "$OUTPUT" | grep -qiE "autres|prochaines|disponibles|évaluations|prérequis"; then
            ok "$task guide vers les commandes suivantes"
        else
            fail "$task ne guide pas vers les commandes suivantes"
        fi
    else
        fail "$task n'affiche pas de message d'usage"
    fi
done

# ─────────────────────────────────────────────────────────────────────────────
# 5. Les scripts support existent
# ─────────────────────────────────────────────────────────────────────────────
section "5/6 — Scripts de support"

EXPECTED_SCRIPTS=(
    "scripts/ensure-model.sh"
    "scripts/chat.py"
    "scripts/harness-run.sh"
)

for script in "${EXPECTED_SCRIPTS[@]}"; do
    SCRIPT_FILE="$REPO_DIR/$script"
    if [ -f "$SCRIPT_FILE" ] && [ -x "$SCRIPT_FILE" ]; then
        ok "$script (exécutable)"
    elif [ -f "$SCRIPT_FILE" ]; then
        fail "$script existe mais n'est pas exécutable"
    else
        fail "$script n'existe pas"
    fi
done

# Vérifier que ensure-model.sh propose le téléchargement automatique
if grep -q "Voulez-vous le télécharger" "$REPO_DIR/scripts/ensure-model.sh" 2>/dev/null; then
    ok "ensure-model.sh propose le téléchargement automatique"
else
    fail "ensure-model.sh ne propose pas le téléchargement automatique"
fi

# ─────────────────────────────────────────────────────────────────────────────
# 6. Cohérence profils ↔ tasks
# ─────────────────────────────────────────────────────────────────────────────
section "6/6 — Cohérence profils et tasks"

PROFILES_DIR="$HARNESS_DIR/config/profiles"

# Chaque task agent doit appeler harness_run avec un profil valide
# Le mapping profil→fichier est dans scripts/harness-run.sh
HARNESS_RUN="$REPO_DIR/scripts/harness-run.sh"
if [ -f "$HARNESS_RUN" ]; then
    ok "scripts/harness-run.sh existe"
    for profile_name in coding doc claude copilot; do
        PROFILE_FILE=$(grep "${profile_name})" "$HARNESS_RUN" | grep -oP 'profiles/\K[^"]+' | head -1)
        if [ -n "$PROFILE_FILE" ] && [ -f "$PROFILES_DIR/$PROFILE_FILE" ]; then
            ok "harness-run $profile_name → $PROFILE_FILE (existe)"
        elif [ -n "$PROFILE_FILE" ]; then
            fail "harness-run $profile_name → $PROFILE_FILE (profil manquant !)"
        else
            fail "harness-run $profile_name : mapping introuvable"
        fi
    done
else
    fail "scripts/harness-run.sh manquant"
fi

# Chaque profil doit avoir un provider valide
for profile in "$PROFILES_DIR"/*.yaml; do
    PNAME=$(basename "$profile")
    PROVIDER=$(grep -E "^\s+provider:" "$profile" 2>/dev/null | awk '{print $2}' | head -1)
    PROVIDER="${PROVIDER:-ollama}"
    case "$PROVIDER" in
        ollama|anthropic|openai)
            ok "$PNAME : provider=$PROVIDER (valide)"
            ;;
        *)
            fail "$PNAME : provider=$PROVIDER (inconnu !)"
            ;;
    esac
done

# Aucun profil ne doit avoir default: allow
for profile in "$PROFILES_DIR"/*.yaml; do
    PNAME=$(basename "$profile")
    if grep -qE "^\s+default:\s+allow" "$profile" 2>/dev/null; then
        fail "$PNAME : default: allow (INTERDIT par les hard rules)"
    else
        ok "$PNAME : pas de default: allow"
    fi
done

# ─────────────────────────────────────────────────────────────────────────────
# Rapport
# ─────────────────────────────────────────────────────────────────────────────
TOTAL_END=$(date +%s)
DURATION=$((TOTAL_END - TOTAL_START))

echo ""
echo -e "${BOLD}══════════════════════════════════════════════════════════════${NC}"
if [ $FAIL -eq 0 ]; then
    echo -e "  ${GREEN}${BOLD}TOUS LES TESTS PASSENT${NC}  —  ${GREEN}✓ $PASS passés${NC}, durée ${DURATION}s"
else
    echo -e "  ${RED}${BOLD}$FAIL TESTS EN ÉCHEC${NC}  —  ${GREEN}✓ $PASS passés${NC}, ${RED}✗ $FAIL échoués${NC}, durée ${DURATION}s"
fi
echo -e "${BOLD}══════════════════════════════════════════════════════════════${NC}"

[ $FAIL -eq 0 ] && exit 0 || exit 1
