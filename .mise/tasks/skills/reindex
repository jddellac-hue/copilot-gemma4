#!/usr/bin/env bash
#MISE description="Reconstruire la base vectorielle Chroma (skills/ + dossiers extra)"
set -euo pipefail

REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"
HARNESS_DIR="$REPO_DIR/agent-harness"
SKILLS_DIR="$REPO_DIR/skills"
VENV="$HARNESS_DIR/.venv"

if [ ! -f "$VENV/bin/python3" ]; then
    echo "[ERREUR] agent-harness non installé"
    echo "  → mise run agent:setup"
    exit 1
fi

if ! "$VENV/bin/python3" -c "import chromadb" 2>/dev/null; then
    echo "[ERREUR] chromadb non installé"
    echo "  → $VENV/bin/pip install agent-harness[rag]"
    exit 1
fi

# --- Parse arguments: --force flag + extra directory paths ---
FORCE=""
EXTRA_DIRS=()
for arg in "$@"; do
    if [ "$arg" = "--force" ]; then
        FORCE="--force"
    elif [ -d "$arg" ]; then
        EXTRA_DIRS+=("$(cd "$arg" && pwd)")
    else
        echo "[ERREUR] Dossier introuvable : $arg"
        echo ""
        echo "Usage : mise run skills:reindex [-- [--force] [EXTRA_DIR...]]"
        echo ""
        echo "Exemples :"
        echo "  mise run skills:reindex                          # skills/ uniquement"
        echo "  mise run skills:reindex -- ../mon-wiki           # skills/ + wiki"
        echo "  mise run skills:reindex -- --force ../docs ../adr"
        exit 1
    fi
done

PERSIST_DIR="$HOME/.local/share/agent-harness/chroma"
STAMP="$PERSIST_DIR/.skills_indexed_at"

if [ "$FORCE" = "--force" ]; then
    echo "[...] Suppression de l'ancien index..."
    rm -rf "$PERSIST_DIR/agent_skills" "$PERSIST_DIR/chat_skills" "$STAMP" 2>/dev/null || true
fi

# Skip if index is already up-to-date (last commit on skills/ vs stamp)
# Force reindex if extra dirs are provided (no git tracking for those)
if [ -f "$STAMP" ] && [ "$FORCE" != "--force" ] && [ ${#EXTRA_DIRS[@]} -eq 0 ]; then
    LAST_COMMIT_TS=$(git -C "$REPO_DIR" log -1 --format=%ct -- skills/ 2>/dev/null || echo 0)
    STAMP_TS=$(stat -c %Y "$STAMP" 2>/dev/null || echo 0)
    if [ "$LAST_COMMIT_TS" -le "$STAMP_TS" ] && [ "$LAST_COMMIT_TS" -gt 0 ]; then
        echo "[OK] Index déjà à jour (dernier commit skills/ antérieur au dernier reindex)"
        echo "     Dernier commit : $(date -d @"$LAST_COMMIT_TS" '+%Y-%m-%d %H:%M')"
        echo "     Dernier index  : $(date -d @"$STAMP_TS" '+%Y-%m-%d %H:%M')"
        echo ""
        echo "  Pour forcer : mise run skills:reindex -- --force"
        exit 0
    fi
fi

# Build JSON array of all source directories
SOURCE_DIRS_JSON="[\"$SKILLS_DIR\""
for d in "${EXTRA_DIRS[@]}"; do
    SOURCE_DIRS_JSON+=",\"$d\""
done
SOURCE_DIRS_JSON+="]"

echo "=== Reconstruction de la base vectorielle ==="
echo "Sources :"
echo "  [1] $SKILLS_DIR (skills)"
for i in "${!EXTRA_DIRS[@]}"; do
    echo "  [$((i+2))] ${EXTRA_DIRS[$i]} (extra)"
done
echo "Chroma  : $PERSIST_DIR"
echo ""

PYTHONUNBUFFERED=1 "$VENV/bin/python3" -c "
import sys, json, os, time, hashlib
from pathlib import Path

sys.path.insert(0, '$HARNESS_DIR/src')
from harness.tools.runbooks import _split_markdown
from harness.tools.skills import SkillsConfig, _detect_domain, build_skills_tools

source_dirs = json.loads('$SOURCE_DIRS_JSON')
persist_dir = Path('$PERSIST_DIR')

# --- Phase 1 : Indexation de toutes les sources ---
import chromadb

persist_dir.mkdir(parents=True, exist_ok=True)
client = chromadb.PersistentClient(path=str(persist_dir))
collection = client.get_or_create_collection(name='agent_skills')

all_domains = []
t0 = time.time()
total_chunks = 0
domain_idx = 0

for source_dir in source_dirs:
    source_path = Path(source_dir)
    if not source_path.is_dir():
        print(f'[WARN] {source_dir} is not a directory, skipping')
        continue

    domains = sorted([
        d.name for d in source_path.iterdir()
        if d.is_dir() and any(d.rglob('*.md'))
    ])

    if not domains:
        # Maybe .md files are at root level — treat the directory itself as a single domain
        md_files = list(source_path.glob('*.md'))
        if md_files:
            domains = [source_path.name]
            # Index root-level files as a single domain
            domain_chunks = 0
            for f in sorted(md_files):
                try:
                    text = f.read_text(encoding='utf-8')
                except UnicodeDecodeError:
                    continue
                file_hash = hashlib.sha256(text.encode('utf-8')).hexdigest()
                rel = f.name
                chunks = _split_markdown(text, 800, 100)
                ids, documents, metadatas = [], [], []
                for idx, (section, body) in enumerate(chunks):
                    ids.append(f'{file_hash}:{idx}')
                    documents.append(body)
                    metadatas.append({'file': rel, 'section': section, 'domain': source_path.name, 'chunk_index': str(idx)})
                if ids:
                    collection.upsert(ids=ids, documents=documents, metadatas=metadatas)
                    domain_chunks += len(ids)
            total_chunks += domain_chunks
            domain_idx += 1
            elapsed = time.time() - t0
            print(f'  [{domain_idx:2d}] {source_path.name:<14s} {domain_chunks:4d} chunks  ({elapsed:.0f}s)', flush=True)
            all_domains.append(source_path.name)
            continue

    for domain in domains:
        domain_dir = source_path / domain
        md_files = sorted(domain_dir.rglob('*.md'))
        domain_chunks = 0

        for f in md_files:
            if not f.is_file():
                continue
            try:
                text = f.read_text(encoding='utf-8')
            except UnicodeDecodeError:
                continue
            file_hash = hashlib.sha256(text.encode('utf-8')).hexdigest()
            rel = f.relative_to(source_path).as_posix()
            chunks = _split_markdown(text, 800, 100)

            ids, documents, metadatas = [], [], []
            for idx, (section, body) in enumerate(chunks):
                ids.append(f'{file_hash}:{idx}')
                documents.append(body)
                metadatas.append({'file': rel, 'section': section, 'domain': domain, 'chunk_index': str(idx)})

            if ids:
                collection.upsert(ids=ids, documents=documents, metadatas=metadatas)
                domain_chunks += len(ids)

        total_chunks += domain_chunks
        domain_idx += 1
        elapsed = time.time() - t0
        print(f'  [{domain_idx:2d}] {domain:<14s} {domain_chunks:4d} chunks  ({elapsed:.0f}s)', flush=True)
        all_domains.append(domain)

elapsed = time.time() - t0

# Stats
chroma_size = sum(f.stat().st_size for f in persist_dir.rglob('*') if f.is_file())
chroma_size_mb = chroma_size / (1024 * 1024)
total_md = sum(
    sum(1 for _ in Path(d).rglob('*.md'))
    for d in source_dirs if Path(d).is_dir()
)
total_md_bytes = sum(
    sum(f.stat().st_size for f in Path(d).rglob('*.md') if f.is_file())
    for d in source_dirs if Path(d).is_dir()
)

print()
print(f'[OK] Index reconstruit en {elapsed:.1f}s')
print()
print(f'  Chunks       : {total_chunks}')
domain_list = ', '.join(all_domains)
print(f'  Domaines     : {len(all_domains)} ({domain_list})')
print(f'  Fichiers .md : {total_md} ({total_md_bytes / 1024:.0f} Ko source)')
print(f'  Chroma DB    : {persist_dir} ({chroma_size_mb:.1f} Mo)')
print()

# --- Phase 2 : Tests RAG sur les domaines skills/ (ceux qu'on connaît) ---
skills_path = Path('$SKILLS_DIR')
config = SkillsConfig(
    enabled=True, path=skills_path, collection_name='agent_skills',
    persist_dir=persist_dir, chunk_size=800, chunk_overlap=100, max_results=5,
)
tools = build_skills_tools(config)
if not tools:
    print('[ERREUR] build_skills_tools a retourné une liste vide')
    sys.exit(1)

search = tools[0]

DOMAIN_QUERIES = {
    'angular':    'Angular standalone components signals testing',
    'base':       'Oracle Flyway migration schemas Docker',
    'concourse':  'Concourse pipeline jobs resources tasks',
    'cutter':     'Cookiecutter Streamlit uv Kustomize',
    'devops':     'conventional commits semantic versioning CI/CD',
    'dsn':        'DSN fragment unicité N4DS declaration sociale',
    'dynatrace':  'DQL fetch filter tags entity Grail',
    'java':       'JUnit 5 DisplayName AssertJ MockitoBean',
    'kubernetes': 'pod CrashLoopBackOff diagnostic GitOps ArgoCD',
    'mermaid':    'Mermaid sequence diagram flowchart mindmap',
    'mise':       'mise task shebang pipefail toml',
    'oracle':     'CDB PDB ARCHIVELOG GoldenGate tablespace',
    'quarkus':    'Kafka acknowledgment strategy Quarkus reactive',
    'rabbitmq':   'RabbitMQ dead letter exchange quorum queue DLX',
    'spring':     'Spring Boot autoconfiguration JPA Security Actuator',
    'sre':        'SLI SLO error budget golden signals PVH',
    'tanzu':      'BOSH Diego cf push Cloud Foundry Tanzu',
    'test':       'Docker Compose Behave Playwright E2E Oracle',
}

# Only test domains that are in skills/ AND have a known query
skills_domains = sorted([
    d.name for d in skills_path.iterdir()
    if d.is_dir() and any(d.rglob('*.md'))
])
testable = [d for d in skills_domains if d in DOMAIN_QUERIES]

print(f'=== Tests RAG — {len(testable)} domaines skills/ ===')
t1 = time.time()
passed = 0
failed = 0
for i, domain in enumerate(testable, 1):
    query = DOMAIN_QUERIES[domain]
    r = search.invoke({'query': query, 'domain': domain, 'top_k': 1})
    if r.ok and domain in r.content.lower():
        print(f'  [{i:2d}/{len(testable)}] ✓ {domain}', flush=True)
        passed += 1
    else:
        excerpt = r.content[:80].replace(chr(10), ' ') if r.ok else 'ERROR'
        print(f'  [{i:2d}/{len(testable)}] ✗ {domain} — {excerpt}', flush=True)
        failed += 1

elapsed_rag = time.time() - t1
print()
if failed:
    print(f'[ECHEC] {passed} passés, {failed} échoués ({elapsed_rag:.1f}s)')
    sys.exit(1)
print(f'[OK] {passed}/{passed} domaines vérifiés ({elapsed_rag:.1f}s)')

# Mettre à jour le stamp
Path('$PERSIST_DIR/.skills_indexed_at').touch()
" || exit 1

echo ""
echo "Prochaines étapes :"
echo "  mise run agent:coding -- \"tâche\"    L'agent utilisera l'index mis à jour"
echo "  mise run chat -- coding              Le chat aussi"
if [ ${#EXTRA_DIRS[@]} -gt 0 ]; then
    echo ""
    echo "Note : les dossiers extra sont indexés dans la même collection."
    echo "  search_rag trouvera les résultats sans filtre domaine."
    echo "  Pour re-indexer avec les extras : relancer avec les mêmes arguments."
fi
