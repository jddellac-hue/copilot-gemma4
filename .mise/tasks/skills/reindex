#!/usr/bin/env bash
#MISE description="Reconstruire la base vectorielle Chroma à partir de skills/"
set -euo pipefail

REPO_DIR="${MISE_PROJECT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"
HARNESS_DIR="$REPO_DIR/agent-harness"
SKILLS_DIR="$REPO_DIR/skills"
VENV="$HARNESS_DIR/.venv"

if [ ! -f "$VENV/bin/python3" ]; then
    echo "[ERREUR] agent-harness non installé"
    echo "  → mise run agent:setup"
    exit 1
fi

if ! "$VENV/bin/python3" -c "import chromadb" 2>/dev/null; then
    echo "[ERREUR] chromadb non installé"
    echo "  → $VENV/bin/pip install agent-harness[rag]"
    exit 1
fi

FORCE="${1:-}"
PERSIST_DIR="$HOME/.local/share/agent-harness/chroma"

if [ "$FORCE" = "--force" ]; then
    echo "[...] Suppression de l'ancien index..."
    rm -rf "$PERSIST_DIR/agent_skills" "$PERSIST_DIR/chat_skills" 2>/dev/null || true
fi

echo "=== Reconstruction de la base vectorielle ==="
echo "Skills    : $SKILLS_DIR"
echo "Chroma    : $PERSIST_DIR"
echo ""

# Compter les domaines et fichiers
DOMAIN_COUNT=$(find "$SKILLS_DIR" -mindepth 1 -maxdepth 1 -type d | wc -l)
FILE_COUNT=$(find "$SKILLS_DIR" -name "*.md" -type f | wc -l)
echo "Domaines  : $DOMAIN_COUNT"
echo "Fichiers  : $FILE_COUNT"
echo ""

PYTHONUNBUFFERED=1 "$VENV/bin/python3" -c "
import sys, json, os, time, hashlib
from pathlib import Path

sys.path.insert(0, '$HARNESS_DIR/src')
from harness.tools.runbooks import _split_markdown
from harness.tools.skills import SkillsConfig, _detect_domain, build_skills_tools

skills_path = Path('$SKILLS_DIR')
persist_dir = Path('$PERSIST_DIR')

# --- Phase 1 : Indexation domaine par domaine avec progression ---
import chromadb

persist_dir.mkdir(parents=True, exist_ok=True)
client = chromadb.PersistentClient(path=str(persist_dir))
collection = client.get_or_create_collection(name='agent_skills')

domains = sorted([d.name for d in skills_path.iterdir()
                  if d.is_dir() and (d / 'SKILL.md').exists()])

print(f'=== Indexation — {len(domains)} domaines ===')
t0 = time.time()
total_chunks = 0

for i, domain in enumerate(domains, 1):
    domain_dir = skills_path / domain
    md_files = sorted(domain_dir.rglob('*.md'))
    domain_chunks = 0

    for f in md_files:
        if not f.is_file():
            continue
        try:
            text = f.read_text(encoding='utf-8')
        except UnicodeDecodeError:
            continue
        file_hash = hashlib.sha256(text.encode('utf-8')).hexdigest()
        rel = f.relative_to(skills_path).as_posix()
        chunks = _split_markdown(text, 800, 100)

        ids, documents, metadatas = [], [], []
        for idx, (section, body) in enumerate(chunks):
            ids.append(f'{file_hash}:{idx}')
            documents.append(body)
            metadatas.append({'file': rel, 'section': section, 'domain': domain, 'chunk_index': str(idx)})

        if ids:
            collection.upsert(ids=ids, documents=documents, metadatas=metadatas)
            domain_chunks += len(ids)

    total_chunks += domain_chunks
    elapsed = time.time() - t0
    print(f'  [{i:2d}/{len(domains)}] {domain:<14s} {domain_chunks:4d} chunks  ({elapsed:.0f}s)', flush=True)

elapsed = time.time() - t0

# Stats volumétrie
import shutil
chroma_size = sum(f.stat().st_size for f in persist_dir.rglob('*') if f.is_file())
chroma_size_mb = chroma_size / (1024 * 1024)
md_size = sum(f.stat().st_size for f in skills_path.rglob('*.md') if f.is_file())
md_size_kb = md_size / 1024

print()
print(f'[OK] Index reconstruit en {elapsed:.1f}s')
print()
print(f'  Chunks       : {total_chunks}')
print(f'  Domaines     : {len(domains)}')
print(f'  Fichiers .md : {sum(1 for _ in skills_path.rglob("*.md"))} ({md_size_kb:.0f} Ko source)')
print(f'  Chroma DB    : {persist_dir} ({chroma_size_mb:.1f} Mo)')
print()

# --- Phase 2 : Tests RAG domaine par domaine ---
config = SkillsConfig(
    enabled=True, path=skills_path, collection_name='agent_skills',
    persist_dir=persist_dir, chunk_size=800, chunk_overlap=100, max_results=5,
)
tools = build_skills_tools(config)
if not tools:
    print('[ERREUR] build_skills_tools a retourné une liste vide')
    sys.exit(1)

search = tools[0]

DOMAIN_QUERIES = {
    'angular':    'Angular standalone components signals testing',
    'base':       'Oracle Flyway migration schemas Docker',
    'concourse':  'Concourse pipeline jobs resources tasks',
    'cutter':     'Cookiecutter Streamlit uv Kustomize',
    'devops':     'conventional commits semantic versioning CI/CD',
    'dsn':        'DSN fragment unicité N4DS declaration sociale',
    'dynatrace':  'DQL fetch filter tags entity Grail',
    'java':       'JUnit 5 DisplayName AssertJ MockitoBean',
    'kubernetes': 'pod CrashLoopBackOff diagnostic GitOps ArgoCD',
    'mermaid':    'Mermaid sequence diagram flowchart mindmap',
    'mise':       'mise task shebang pipefail toml',
    'oracle':     'CDB PDB ARCHIVELOG GoldenGate tablespace',
    'quarkus':    'Kafka acknowledgment strategy Quarkus reactive',
    'rabbitmq':   'RabbitMQ dead letter exchange quorum queue DLX',
    'spring':     'Spring Boot autoconfiguration JPA Security Actuator',
    'sre':        'SLI SLO error budget golden signals PVH',
    'tanzu':      'BOSH Diego cf push Cloud Foundry Tanzu',
    'test':       'Docker Compose Behave Playwright E2E Oracle',
}

print(f'=== Tests RAG — {len(domains)} domaines ===')
t1 = time.time()
passed = 0
failed = 0
for i, domain in enumerate(domains, 1):
    query = DOMAIN_QUERIES.get(domain, f'{domain} documentation')
    r = search.invoke({'query': query, 'domain': domain, 'top_k': 1})
    if r.ok and domain in r.content.lower():
        print(f'  [{i:2d}/{len(domains)}] ✓ {domain}', flush=True)
        passed += 1
    else:
        excerpt = r.content[:80].replace(chr(10), ' ') if r.ok else 'ERROR'
        print(f'  [{i:2d}/{len(domains)}] ✗ {domain} — {excerpt}', flush=True)
        failed += 1

elapsed_rag = time.time() - t1
print()
if failed:
    print(f'[ECHEC] {passed} passés, {failed} échoués ({elapsed_rag:.1f}s)')
    sys.exit(1)
print(f'[OK] {passed}/{passed} domaines vérifiés ({elapsed_rag:.1f}s)')

# Mettre à jour le stamp pour _ensure_skills_index
Path('$PERSIST_DIR/.skills_indexed_at').touch()
" || exit 1

echo ""
echo "Prochaines étapes :"
echo "  mise run agent:coding -- \"tâche\"    L'agent utilisera l'index mis à jour"
echo "  mise run chat -- coding              Le chat aussi"
