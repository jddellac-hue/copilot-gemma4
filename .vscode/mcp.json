{
  "_comment": "VS Code Copilot MCP server declarations. Mirrors .github/mcp/servers.json.",
  "servers": {
    "gemma4-coding": {
      "command": "agent-harness/.venv/bin/harness",
      "args": [
        "mcp-serve",
        "--profile",
        "agent-harness/config/profiles/gemma4-coding.yaml",
        "--workspace",
        "${workspaceFolder}"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "no_proxy": "localhost,127.0.0.1"
      }
    }
  }
}
